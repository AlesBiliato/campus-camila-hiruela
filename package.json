{
  "name": "campus-camila-hiruela",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run sass && concurrently \"npm run sass:watch\" \"vite\"",
    "build": "npm run sass && vite build",
    "preview": "vite preview",
    "sass": "sass sass/main.scss css/estilos.css --no-source-map",
    "sass:watch": "sass --watch sass/main.scss:css/estilos.css --no-source-map"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "sass": "^1.99.0",
    "vite": "^7.3.2"
  }
}
